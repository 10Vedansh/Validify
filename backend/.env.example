# ─── Validify API — Environment Variables ───────────────────────────────
#
# Copy this file to .env and fill in your values.
# For production, all secrets MUST be set via the deployment platform's
# environment variable configuration (not this file).
#
# Required variables are marked with [REQUIRED].
# ────────────────────────────────────────────────────────────────────────

# ─── App ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# URL of the deployed frontend (used for CORS).
# In development, the server also auto-adds localhost:3000, 5173, 8081.
# In production, set this to your Vercel / Cloudflare domain.
# Example: https://validify.vercel.app
# [REQUIRED in production]
FRONTEND_URL=http://localhost:3000

# ─── Database (Supabase PostgreSQL) ─────────────────────────────────────
# Connection string from Supabase → Project Settings → Database → Connection URI.
# Format: postgresql://user:password@host:port/database?sslmode=require
# [REQUIRED]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/validify"

# Direct connection (bypasses connection pooler for migrations).
# Use the same value as DATABASE_URL, but without ?pgbouncer=true if pooling.
# [REQUIRED for migrations]
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/validify"

# ─── JWT ────────────────────────────────────────────────────────────────
# Generate strong secrets:
#   openssl rand -base64 64 | tr -d '\n'
# [REQUIRED — minimum 48 characters]
JWT_ACCESS_SECRET="change-me-to-a-random-64-char-string-in-production"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-string-in-production"

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Gemini AI (Validation Engine, Chat, Pitch Decks) ───────────────────
# Get your API key at https://aistudio.google.com/apikey
# [REQUIRED for AI features; leave empty to disable]
GEMINI_API_KEY=

# Model selection
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash-lite
