generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Core user account mapped from frontend User type.
model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  name                 String
  passwordHash         String         @map("password_hash")
  avatarUrl            String?        @map("avatar_url")
  plan                 Plan           @default(FREE)
  stripeCustomerId     String?        @unique @map("stripe_customer_id")
  stripeSubscriptionId String?        @unique @map("stripe_subscription_id")
  emailVerified        Boolean        @default(false) @map("email_verified")
  emailVerifiedAt      DateTime?      @map("email_verified_at")
  resetToken           String?        @map("reset_token")
  resetTokenExpiresAt  DateTime?      @map("reset_token_expires_at")
  refreshTokenHash     String?        @map("refresh_token_hash")
  tokenVersion         Int            @default(1) @map("token_version")
  deletedAt            DateTime?      @map("deleted_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  isAdmin              Boolean        @default(false) @map("is_admin")
  apiLogs              ApiLog[]
  chatThreads          ChatThread[]
  ideas                Idea[]
  payments             Payment[]
  pitchDecks           PitchDeck[]
  reports              Report[]
  subscriptions        Subscription[]
  usageRecords         Usage[]
  validations          Validation[]

  @@index([email])
  @@index([plan])
  @@index([stripeCustomerId])
  @@map("users")
}

/// Startup idea — maps to frontend Idea type in startup.ts.
model Idea {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  name          String
  industry      Industry
  problem       String
  audience      String
  businessModel BusinessModel @map("business_model")
  budget        String?
  country       String?
  competitors   String[]
  notes         String?
  attachmentUrl String?       @map("attachment_url")
  deletedAt     DateTime?     @map("deleted_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  chatThreads   ChatThread[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports       Report[]
  validations   Validation[]

  @@index([userId])
  @@index([userId, industry])
  @@index([userId, deletedAt])
  @@index([name])
  @@map("ideas")
}

/// AI validation run — maps to frontend Validation type in startup.ts.
/// Score dimensions are stored as individual columns for querying,
/// and also as a Json bag for flexibility.
model Validation {
  id                String           @id @default(cuid())
  ideaId            String           @map("idea_id")
  userId            String           @map("user_id")
  status            ValidationStatus @default(RUNNING)
  overallScore      Int?             @map("overall_score")
  marketScore       Int?             @map("market_score")
  teamScore         Int?             @map("team_score")
  moatScore         Int?             @map("moat_score")
  monetizationScore Int?             @map("monetization_score")
  tractionScore     Int?             @map("traction_score")
  riskScore         Int?             @map("risk_score")
  rawLlmResponse    Json?            @map("raw_llm_response")
  errorMessage      String?          @map("error_message")
  startedAt         DateTime         @default(now()) @map("started_at")
  completedAt       DateTime?        @map("completed_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  report            Report?
  idea              Idea             @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ideaId])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("validations")
}

/// Investor-grade report — maps to frontend Report type in report.ts.
/// SWOT, competitors, and roadmap are stored as native arrays or Json
/// to match the frontend's exact shape without join tables.
model Report {
  id                String      @id @default(cuid())
  ideaId            String      @map("idea_id")
  validationId      String      @unique @map("validation_id")
  userId            String      @map("user_id")
  title             String
  summary           String
  industry          String
  overallScore      Int         @map("overall_score")
  marketScore       Int         @map("market_score")
  teamScore         Int         @map("team_score")
  moatScore         Int         @map("moat_score")
  monetizationScore Int         @map("monetization_score")
  tractionScore     Int         @map("traction_score")
  riskScore         Int         @map("risk_score")
  strengths         String[]    @default([])
  weaknesses        String[]    @default([])
  opportunities     String[]    @default([])
  threats           String[]    @default([])
  competitors       Json        @default("[]")
  roadmap           Json        @default("[]")
  tam               String?     @map("tam")
  sam               String?     @map("sam")
  som               String?     @map("som")
  pdfUrl            String?     @map("pdf_url")
  createdAt         DateTime    @default(now()) @map("created_at")
  pitchDecks        PitchDeck[]
  idea              Idea        @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  validation        Validation  @relation(fields: [validationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ideaId])
  @@index([userId, createdAt])
  @@map("reports")
}

/// Billing subscription — linked to Stripe subscription object.
/// One user can have at most one active subscription at a time.
/// Historical subscriptions are retained for invoicing audit.
model Subscription {
  id                       String             @id @default(cuid())
  userId                   String             @map("user_id")
  plan                     Plan
  interval                 PlanInterval       @default(MONTHLY) @map("interval")
  status                   SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId     String?            @unique @map("stripe_subscription_id")
  stripeCustomerId         String?            @map("stripe_customer_id")
  stripeSubscriptionItemId String?            @map("stripe_subscription_item_id")
  currentPeriodStart       DateTime           @map("current_period_start")
  currentPeriodEnd         DateTime           @map("current_period_end")
  trialEndsAt              DateTime?          @map("trial_ends_at")
  canceledAt               DateTime?          @map("canceled_at")
  unitPrice                Int?               @map("unit_price")
  currency                 String             @default("usd")
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")
  payments                 Payment[]
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSubscriptionId])
  @@index([userId, status])
  @@index([status])
  @@map("subscriptions")
}

/// Payment transaction record — one per invoice / charge.
model Payment {
  id                    String        @id @default(cuid())
  userId                String        @map("user_id")
  subscriptionId        String?       @map("subscription_id")
  stripeInvoiceId       String?       @map("stripe_invoice_id")
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  amount                Int
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  description           String?
  paidAt                DateTime?     @map("paid_at")
  refundedAt            DateTime?     @map("refunded_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  subscription          Subscription? @relation(fields: [subscriptionId], references: [id])
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
  @@index([userId, createdAt])
  @@index([stripeInvoiceId])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

/// Metered usage record — tracked per action for plan enforcement
/// and Stripe usage-based billing.
model Usage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  quantity  Int      @default(1)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, action])
  @@index([userId, createdAt])
  @@index([userId, action, createdAt])
  @@map("usage_records")
}

/// Audit log for API requests — used for debugging, rate limiting analysis,
/// and security monitoring. Retention: 90 days (handled by cleanup job).
model ApiLog {
  id             String   @id @default(cuid())
  userId         String?  @map("user_id")
  method         String
  path           String
  query          String?
  statusCode     Int      @map("status_code")
  durationMs     Int      @map("duration_ms")
  requestHeaders Json?    @map("request_headers")
  requestBody    String?  @map("request_body")
  responseBody   String?  @map("response_body")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([statusCode])
  @@index([path])
  @@index([method, path])
  @@index([createdAt], map: "api_logs_created_at_ttl_idx")
  @@map("api_logs")
}

/// Conversation thread — maps to frontend ChatThread type in report.ts.
model ChatThread {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  ideaId    String?       @map("idea_id")
  title     String
  updatedAt DateTime      @updatedAt @map("updated_at")
  createdAt DateTime      @default(now()) @map("created_at")
  messages  ChatMessage[]
  idea      Idea?         @relation(fields: [ideaId], references: [id])
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, updatedAt])
  @@map("chat_threads")
}

/// Individual message within a thread — maps to frontend ChatMessage type.
model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String     @map("thread_id")
  role      String
  content   String
  model     String?
  tokensIn  Int?       @map("tokens_in")
  tokensOut Int?       @map("tokens_out")
  createdAt DateTime   @default(now()) @map("created_at")
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([threadId, createdAt])
  @@map("chat_messages")
}

/// Generated pitch deck — stores slide content as JSON.
model PitchDeck {
  id        String   @id @default(cuid())
  reportId  String   @map("report_id")
  userId    String   @map("user_id")
  title     String
  content   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reportId])
  @@index([userId, createdAt])
  @@map("pitch_decks")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE

  @@map("plan")
}

enum PlanInterval {
  MONTHLY
  ANNUAL

  @@map("plan_interval")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
  TRIALING

  @@map("subscription_status")
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  PENDING
  REFUNDED
  CANCELED

  @@map("payment_status")
}

enum ValidationStatus {
  DRAFT
  RUNNING
  COMPLETE
  FAILED

  @@map("validation_status")
}

enum Industry {
  AI_ML        @map("AI / ML")
  FINTECH      @map("Fintech")
  HEALTHTECH   @map("Healthtech")
  CLIMATE      @map("Climate")
  DEVTOOLS     @map("DevTools")
  CONSUMER     @map("Consumer")
  PRODUCTIVITY @map("Productivity")

  @@map("industry")
}

enum BusinessModel {
  SAAS          @map("SaaS")
  MARKETPLACE   @map("Marketplace")
  TRANSACTIONAL @map("Transactional")
  USAGE_BASED   @map("Usage-based")
  FREEMIUM      @map("Freemium")

  @@map("business_model")
}
