# ─── Validify Frontend — Environment Variables ──────────────────────────
#
# Copy this file to .env and fill in your values.
# In production, set these via Vercel's dashboard or Cloudflare Workers secrets.
#
# All variables prefixed with VITE_ are exposed to the browser.
# Do NOT put secrets in VITE_ variables.
# ────────────────────────────────────────────────────────────────────────

# URL of the deployed backend API.
# [REQUIRED]
# Vercel example:    VITE_API_URL=https://validify-api.railway.app/api
# Local example:     VITE_API_URL=http://localhost:8080/api
VITE_API_URL=http://localhost:8080/api

# Application name (displayed in UI).
VITE_APP_NAME=Validify
